# ProjectFlow Backend - Environment Variables
# Copy to .env for local development

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/projectflow

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (generate with: openssl rand -hex 64) ────────────────────
JWT_SECRET=change-this-to-a-random-64-char-hex-string
JWT_REFRESH_SECRET=change-this-to-a-different-random-64-char-hex-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ─────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Email (SMTP) ─────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=ProjectFlow <noreply@yourdomain.com>

# ── Google OAuth ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── File Uploads ─────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=debug
